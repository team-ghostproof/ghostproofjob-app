# GhostProofJob — test environment variables (copy to .env and fill in; the
# real .env is gitignored — NEVER commit credentials, this repo is public).
#
# Playwright signed-in harness (tests/auth.setup.js). In GitHub Actions, set
# these as repository secrets (Settings → Secrets and variables → Actions);
# e2e.yml passes them through. Without TEST_USER_PASSWORD the authed suite
# self-skips and everything else stays green.

# Firebase test account (Aaliyah's test login)
TEST_USER_EMAIL=asosa@ghostproofjob.com
TEST_USER_PASSWORD=

# Optional: point the suite at a deployed URL instead of the local server
# GPJ_BASE_URL=http://localhost:8000
