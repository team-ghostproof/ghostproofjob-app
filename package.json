{
  "name": "gpj-job-pipeline",
  "version": "1.0.0",
  "description": "GhostProofJob global job sourcing pipeline (Firebase Cloud Functions)",
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test smoke",
    "screenshots": "playwright test screenshots",
    "report": "playwright show-report",
    "test:match": "node --test tests/match/reverseMatch.test.mjs tests/match/r3pipeline.test.mjs tests/recruiter/domainCheck.test.mjs",
    "test:growth": "node --test tests/growth/ghostContent.test.mjs",
    "test:email": "node --test tests/email/optout.test.mjs",
    "test:rules": "firebase emulators:exec --only firestore \"node --test tests/rules/firestore-rules.test.mjs\"",
    "content:weekly": "node ghost-report-generator/run.js",
    "content:sample": "node ghost-report-generator/run.js --fixture"
  },
  "dependencies": {
    "@sparticuz/chromium": "^123.0.1",
    "axios": "^1.7.2",
    "firebase-admin": "^12.1.0",
    "firebase-functions": "^5.0.0",
    "puppeteer-core": "^22.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@firebase/rules-unit-testing": "^3.0.4",
    "firebase": "^10.12.0",
    "firebase-tools": "^13.0.0"
  },
  "private": true
}
