'use strict';
/**
 * api/notifications/sendAutomatedEmail.js
 * Transactional email hook (Resend/SendGrid) that respects each user's
 * Firestore notification preferences map before sending.
 *
 * Env: RESEND_API_KEY (or SENDGRID_API_KEY), EMAIL_FROM
 * Preference keys checked: newJobMatches, ghostRiskAlerts,
 *   coverLetterOffers, companyRatingReminders
 */

const PREF_FOR_TYPE = {
  new_job_matches: 'newJobMatches',
  ghost_risk_alert: 'ghostRiskAlerts',
  cover_letter_offer: 'coverLetterOffers',
  company_rating_reminder: 'companyRatingReminders',
};

/** True only if the user's preferences map explicitly allows this email type. */
function isAllowed(preferences, type) {
  const key = PREF_FOR_TYPE[type];
  if (!key) return false;
  if (!preferences || typeof preferences !== 'object') return false;
  // default OFF unless explicitly true — opt-in safety
  return preferences[key] === true;
}

async function sendViaResend(apiKey, payload) {
  const res = await fetch('https://api.resend.com/emails', {
    method: 'POST',
    headers: { Authorization: 'Bearer ' + apiKey, 'Content-Type': 'application/json' },
    body: JSON.stringify(payload),
  });
  return res.ok;
}

async function sendViaSendGrid(apiKey, fromAddr, to, subject, html) {
  const res = await fetch('https://api.sendgrid.com/v3/mail/send', {
    method: 'POST',
    headers: { Authorization: 'Bearer ' + apiKey, 'Content-Type': 'application/json' },
    body: JSON.stringify({
      personalizations: [{ to: [{ email: to }] }],
      from: { email: fromAddr },
      subject,
      content: [{ type: 'text/html', value: html }],
    }),
  });
  return res.ok;
}

/**
 * Send one transactional email if the user's prefs allow it.
 * @param {object} user { email, preferences }
 * @param {string} type one of PREF_FOR_TYPE keys
 * @param {object} content { subject, html }
 * @returns {Promise<{sent:boolean, reason?:string}>}
 */
async function sendAutomatedEmail(user, type, content) {
  if (!user || !user.email) return { sent: false, reason: 'no_recipient' };
  if (!isAllowed(user.preferences, type)) return { sent: false, reason: 'pref_disabled' };

  const from = process.env.EMAIL_FROM || 'GhostProofJob <noreply@ghostproofjob.com>';
  const subject = (content && content.subject) || 'GhostProofJob';
  const html = (content && content.html) || '';

  try {
    if (process.env.RESEND_API_KEY) {
      const ok = await sendViaResend(process.env.RESEND_API_KEY, { from, to: user.email, subject, html });
      return { sent: ok, reason: ok ? undefined : 'provider_error' };
    }
    if (process.env.SENDGRID_API_KEY) {
      const ok = await sendViaSendGrid(process.env.SENDGRID_API_KEY, from.replace(/.*<|>.*/g, '') || from, user.email, subject, html);
      return { sent: ok, reason: ok ? undefined : 'provider_error' };
    }
    return { sent: false, reason: 'no_provider_configured' };
  } catch (e) {
    console.error('[sendAutomatedEmail]', e && e.message);
    return { sent: false, reason: 'exception' };
  }
}

/**
 * Batch loop — only sends to users whose prefs permit the type.
 * @param {Array} users [{email, preferences}]
 */
async function sendBatch(users, type, contentFor) {
  const list = Array.isArray(users) ? users : [];
  const results = { attempted: 0, sent: 0, skipped: 0 };
  for (const u of list) {
    if (!isAllowed(u.preferences, type)) { results.skipped++; continue; }
    results.attempted++;
    const content = typeof contentFor === 'function' ? contentFor(u) : contentFor;
    const r = await sendAutomatedEmail(u, type, content);
    if (r.sent) results.sent++;
  }
  return results;
}

module.exports = { sendAutomatedEmail, sendBatch, isAllowed, PREF_FOR_TYPE };
