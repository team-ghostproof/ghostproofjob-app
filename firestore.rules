rules_version = '2';
// ============================================================================
// GhostProofJob — Firestore Security Rules  (R0, recruiter-tier foundation)
// ----------------------------------------------------------------------------
// INSERT-ONLY over the founder's LIVE console rules (provided 2026-07-06). Every
// existing block is preserved verbatim; recruiter blocks are ADDED.
//
// TWO reconciliations vs the pasted live rules (both intentional, flagged):
//  (A) The live `jobs` block was `allow write: if false`. The recruiter tier
//      REQUIRES a recruiter to create/edit their OWN internal job. Changed to a
//      SCOPED write (admin, or recruiter on their own source:'internal' job).
//      Harvested jobs (no ownerUid / source:'jobspy') stay untouchable — same
//      practical effect as `if false` for every existing/harvested doc.
//  (B) In the pasted live rules, `keyword_templates` / `ai_sentence_cache` /
//      `user_usage` / `hired` were nested INSIDE the `bugReports` block (a brace
//      slip), which makes them subcollections of bugReports, not top-level — so
//      top-level `hired` (which the app writes) was effectively default-denied.
//      They are restored to TOP LEVEL here, exactly where the live comment says
//      to put them ("alongside your current /jobs, /profiles, /bugReports").
//      ⚠️ Verify current live `hired` writes actually succeed before relying on
//      this — the app guards fb.logHire in try/catch, so a live denial is silent.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Founder/admin check — confirmed complete (asosa@, ksosa@).
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
             'asosa@ghostproofjob.com', 'ksosa@ghostproofjob.com'
           ];
    }

    // ---- recruiter helpers (NEW) -------------------------------------------
    function signedIn() { return request.auth != null; }
    function isRecruiter() {
      return signedIn()
        && exists(/databases/$(database)/documents/recruiters/$(request.auth.uid));
    }
    function jobOwner(jobId) {
      return get(/databases/$(database)/documents/jobs/$(jobId)).data.ownerUid;
    }

    // 1. PUBLIC READ ACCESS FOR JOBS
    match /jobs/{jobId} {
      allow read: if true;
      // (A) was `if false`. Now scoped: admin, or a recruiter creating/editing
      // ONLY their own internal job. Harvested jobs stay untouchable.
      allow create: if isAdmin()
        || (isRecruiter()
            && request.resource.data.ownerUid == request.auth.uid
            && request.resource.data.source == 'internal');
      allow update, delete: if isAdmin()
        || (isRecruiter()
            && resource.data.ownerUid == request.auth.uid
            && resource.data.source == 'internal');

      // ---- NEW: applications — candidate owns own; owner recruiter reads ----
      match /applications/{candidateUid} {
        allow create: if signedIn() && request.auth.uid == candidateUid;
        allow read:   if isAdmin()
                        || (signedIn() && request.auth.uid == candidateUid)
                        || (isRecruiter() && jobOwner(jobId) == request.auth.uid);
        allow update: if isAdmin()
                        || (signedIn() && request.auth.uid == candidateUid)
                        || (isRecruiter() && jobOwner(jobId) == request.auth.uid);
        allow delete: if isAdmin() || (signedIn() && request.auth.uid == candidateUid);
      }

      // ---- NEW: recommended_candidates — backend-written; owner recruiter reads ----
      match /recommended_candidates/{candUid} {
        allow read:  if isAdmin() || (isRecruiter() && jobOwner(jobId) == request.auth.uid);
        allow write: if false;   // Admin SDK only (reverse-match scorer)
      }
    }

    // 2. PROFILES (unchanged from live)
    match /profiles/{userId} {
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);
      allow write: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);
    }

    // 3. Bug reports / contact (unchanged from live)
    match /bugReports/{doc} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // keyword_templates (top-level; unchanged intent)
    match /keyword_templates/{kw} {
      allow read: if true;
      allow write: if false;
    }
    // ai_sentence_cache — Cloud Function only (unchanged intent)
    match /ai_sentence_cache/{key} {
      allow read, write: if false;
    }
    // user_usage — self-read, backend-write (unchanged intent)
    match /user_usage/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
    // hired — any signed-in create/read (unchanged intent; restored to top level)
    match /hired/{doc} {
      allow create, read: if request.auth != null;
    }

    // ======================= NEW: RECRUITER TIER ============================
    match /recruiters/{rId} {
      allow read:   if (request.auth != null && request.auth.uid == rId) || isAdmin();
      allow create: if request.auth != null && request.auth.uid == rId;
      // a recruiter may edit their own profile but NOT self-flip verification/plan
      allow update: if isAdmin()
        || (request.auth != null && request.auth.uid == rId
            && !( 'isValidated' in request.resource.data
                  && request.resource.data.isValidated != resource.data.get('isValidated', false) )
            && !( 'plan' in request.resource.data
                  && request.resource.data.plan != resource.data.get('plan', 'free') ));
      allow delete: if isAdmin();
    }

    // canonical company records — public READ; reputation/verified fields backend-only
    match /companies/{companyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // recruiter-visible candidate projection — backend-written; contact only when
    // the backend confirmed consent. Clients never write.
    match /candidate_cards/{candUid} {
      allow read:  if isAdmin() || isRecruiter();
      allow write: if false;
    }

    // per-candidate match-token cache — backend-written; self/admin/recruiter read
    match /match_tokens/{candUid} {
      allow read:  if (request.auth != null && request.auth.uid == candUid) || isAdmin() || isRecruiter();
      allow write: if false;
    }

    // candidate notification tray — self read/update; inbound backend-written
    match /notifications/{userId}/items/{itemId} {
      allow read:   if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow update: if request.auth != null && request.auth.uid == userId;
      allow create, delete: if false;
    }

    // review appeals — recruiter files own; admin-only read/decide
    match /appeals/{appealId} {
      allow create: if isRecruiter() && request.resource.data.ownerUid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // default deny (implicit — no catch-all needed; unmatched paths are denied)
  }
}
