rules_version = '2';
// ============================================================================
// GhostProofJob — Firestore Security Rules  (R0, recruiter-tier foundation)
// ----------------------------------------------------------------------------
// INSERT-ONLY over the founder's LIVE console rules (provided 2026-07-06). Every
// existing block is preserved verbatim; recruiter blocks are ADDED.
//
// TWO reconciliations vs the pasted live rules (both intentional, flagged):
//  (A) The live `jobs` block was `allow write: if false`. The recruiter tier
//      REQUIRES a recruiter to create/edit their OWN internal job. Changed to a
//      SCOPED write (admin, or recruiter on their own source:'internal' job).
//      Harvested jobs (no ownerUid / source:'jobspy') stay untouchable — same
//      practical effect as `if false` for every existing/harvested doc.
//  (B) In the pasted live rules, `keyword_templates` / `ai_sentence_cache` /
//      `user_usage` / `hired` were nested INSIDE the `bugReports` block (a brace
//      slip), which makes them subcollections of bugReports, not top-level — so
//      top-level `hired` (which the app writes) was effectively default-denied.
//      They are restored to TOP LEVEL here, exactly where the live comment says
//      to put them ("alongside your current /jobs, /profiles, /bugReports").
//      ⚠️ Verify current live `hired` writes actually succeed before relying on
//      this — the app guards fb.logHire in try/catch, so a live denial is silent.
//
// v101b Sprint 3 — RULES HARDENING (pre-recruiter-R2; emulator-proven in CI):
//   1. companies: recruiter may create/update ONLY their own-domain doc and can
//      never self-set verifiedEmployer:true (was admin-only WRITE, which silently
//      denied recruiter-signup's saveCompany).
//   2. jobs update: an owner-recruiter cannot change isValidated/ownerUid/source/
//      companyId (no self-verify past the Employer Verification Queue).
//   3. candidate projections (candidate_cards/match_tokens/recommended_candidates):
//      reads require isRecruiterVerified() (doc exists AND isValidated==true), not
//      bare existence — an unreviewed recruiter sees no candidate data.
//   4. hired: create rejected if it carries any PII key (email/name/uid/…); the
//      pool stays read-open because the app writes only anonymous aggregates.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Founder/admin check — confirmed complete (asosa@, ksosa@).
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
             'asosa@ghostproofjob.com', 'ksosa@ghostproofjob.com'
           ];
    }

    // ---- recruiter helpers (NEW) -------------------------------------------
    function signedIn() { return request.auth != null; }
    function isRecruiter() {
      return signedIn()
        && exists(/databases/$(database)/documents/recruiters/$(request.auth.uid));
    }
    // v101b Sprint 3 (rules hardening): a VERIFIED recruiter — the doc exists AND
    // a human/backend set isValidated:true. Candidate-projection reads gate on
    // THIS, not bare existence, so a self-signed-up-but-unreviewed recruiter can
    // never see candidate data before discovery (R4) ships.
    function isRecruiterVerified() {
      return isRecruiter()
        && get(/databases/$(database)/documents/recruiters/$(request.auth.uid)).data.get('isValidated', false) == true;
    }
    // the email domain on the caller's recruiter doc (owns companies/{domain})
    function recruiterDomain() {
      return get(/databases/$(database)/documents/recruiters/$(request.auth.uid)).data.get('domain', '');
    }
    // v112: the caller's COMPANY-SCOPED role. 'owner' = created the account,
    // 'admin' = invited with admin rights, 'standard' = list + hire only.
    // This is never site-admin (see isAdmin()) — a company admin only ever governs
    // their own company record.
    function recruiterRole() {
      return get(/databases/$(database)/documents/recruiters/$(request.auth.uid)).data.get('role', 'owner');
    }
    function recruiterCompanyId() {
      return get(/databases/$(database)/documents/recruiters/$(request.auth.uid)).data.get('companyId', '');
    }
    function jobOwner(jobId) {
      return get(/databases/$(database)/documents/jobs/$(jobId)).data.ownerUid;
    }

    // 1. PUBLIC READ ACCESS FOR JOBS
    match /jobs/{jobId} {
      allow read: if true;
      // (A) was `if false`. Now scoped: admin, or a recruiter creating/editing
      // ONLY their own internal job. Harvested jobs stay untouchable.
      // R2-B: a recruiter creates their internal job HIDDEN — active:false +
      // isValidated:false — so it never enters the candidate `active==true` deck
      // query until an admin verifies it. (They also can't self-verify/activate
      // on update; see below.)
      allow create: if isAdmin()
        || (isRecruiter()
            && request.resource.data.ownerUid == request.auth.uid
            && request.resource.data.source == 'internal'
            && request.resource.data.get('isValidated', false) == false
            && request.resource.data.get('active', false) == false);
      // v101b Sprint 3: an owner-recruiter may edit their internal job's CONTENT
      // but NEVER self-verify or re-owner it — isValidated / ownerUid / source /
      // companyId are immutable to the recruiter (admin/backend only). Without
      // this, a recruiter could flip their own isValidated:true and bypass the
      // Employer Verification Queue, or reassign the job's owner/company.
      allow update: if isAdmin()
        || (isRecruiter()
            && resource.data.ownerUid == request.auth.uid
            && resource.data.source == 'internal'
            && request.resource.data.ownerUid == resource.data.ownerUid
            && request.resource.data.source == resource.data.source
            && request.resource.data.get('isValidated', false) == resource.data.get('isValidated', false)
            // R2-B: no self-ACTIVATE. R9-D: an owner MAY close their own live role
            // (active true->false) but never activate one (false->true).
            && (request.resource.data.get('active', false) == resource.data.get('active', false)
                || (resource.data.get('active', false) == true && request.resource.data.get('active', false) == false))
            && request.resource.data.get('companyId', '') == resource.data.get('companyId', ''));
      allow delete: if isAdmin()
        || (isRecruiter()
            && resource.data.ownerUid == request.auth.uid
            && resource.data.source == 'internal');

      // ---- NEW: applications — candidate owns own; owner recruiter reads ----
      match /applications/{candidateUid} {
        allow create: if signedIn() && request.auth.uid == candidateUid;
        allow read:   if isAdmin()
                        || (signedIn() && request.auth.uid == candidateUid)
                        || (isRecruiter() && jobOwner(jobId) == request.auth.uid);
        allow update: if isAdmin()
                        || (signedIn() && request.auth.uid == candidateUid)
                        || (isRecruiter() && jobOwner(jobId) == request.auth.uid);
        allow delete: if isAdmin() || (signedIn() && request.auth.uid == candidateUid);
      }

      // ---- NEW: recommended_candidates — backend-written; owner recruiter reads ----
      match /recommended_candidates/{candUid} {
        // v101b Sprint 3: VERIFIED owner-recruiter only (was bare isRecruiter)
        allow read:  if isAdmin() || (isRecruiterVerified() && jobOwner(jobId) == request.auth.uid);
        allow write: if false;   // Admin SDK only (reverse-match scorer)
      }
    }

    // v145 P1-4: EEO / voluntary self-identification — the ONE surface that a hiring
    // employer must NEVER be able to tie to an individual candidate. It therefore
    // lives OUTSIDE jobs/{jobId}/applications (which the owner recruiter CAN read,
    // line ~121) in its own collection, keyed by uid so the rule can verify the
    // writer directly from the path.
    //   • the candidate writes/updates/deletes ONLY their own responses
    //   • read is ADMIN-ONLY — isRecruiter is deliberately absent, so an employer
    //     (verified or not, owner of the job or not) gets zero read at the rules
    //     level. Reporting is aggregate, done with the Admin SDK.
    //   • every field is optional and defaults to "decline"; storing nothing is fine.
    match /eeo_responses/{uid}/jobs/{jobId} {
      // read: the candidate themselves (to review/change their answer) OR admin
      // (aggregate reporting). isRecruiter is deliberately ABSENT — an employer,
      // owner of the job or not, verified or not, gets zero read at the rules level.
      allow read:   if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if isAdmin() || (signedIn() && request.auth.uid == uid);
    }

    // 2. PROFILES (unchanged from live)
    match /profiles/{userId} {
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);
      // v113 SECURITY: `allow write` let the owner set ANY field — including `tier`,
      // which is exactly what isPaid() reads. A user could simply write tier:'life'
      // onto their own profile and unlock the paywall for free. Entitlement + money
      // fields are now BACKEND-ONLY: the Stripe webhook writes them with the admin
      // SDK (bypasses rules), or an admin grants them. Everything else on the profile
      // stays freely user-writable (name, prefs, discoverable, pending_boost, …).
      allow create: if isAdmin()
        || (request.auth != null && request.auth.uid == userId
            && request.resource.data.get('tier', 'free') == 'free'
            && !request.resource.data.keys().hasAny(['paidUntil', 'bonusDays', 'stripeCustomerId']));
      allow update: if isAdmin()
        || (request.auth != null && request.auth.uid == userId
            && request.resource.data.get('tier', 'free') == resource.data.get('tier', 'free')
            && request.resource.data.get('paidUntil', 0) == resource.data.get('paidUntil', 0)
            && request.resource.data.get('bonusDays', 0) == resource.data.get('bonusDays', 0)
            && request.resource.data.get('stripeCustomerId', '') == resource.data.get('stripeCustomerId', ''));
      allow delete: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);   // wipeProfile
    }

    // 3. Bug reports / contact (unchanged from live)
    match /bugReports/{doc} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // keyword_templates (top-level; unchanged intent)
    match /keyword_templates/{kw} {
      allow read: if true;
      allow write: if false;
    }
    // ai_sentence_cache — Cloud Function only (unchanged intent)
    match /ai_sentence_cache/{key} {
      allow read, write: if false;
    }
    // user_usage — self-read, backend-write (unchanged intent)
    match /user_usage/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
    // F-GHOST — cross-user ghost-report aggregate. Signed-in users file a report
    // with NO free-text and NO PII beyond their own uid; the shape is locked so a
    // defamatory comment can never be stored server-side. Reads are for count()
    // aggregation ("N hunters reported this") + the backend content engine.
    match /ghost_reports/{id} {
      allow read: if request.auth != null;
      // v141: reports are now also keyed to the SPECIFIC POSTING (jobKey), so a
      // card can show "N hunters reported this" instead of only a company-level
      // signal. Still shape-locked and PII-free — no free text is ever stored.
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['company','companyKey','stage','ts','reporterUid','jobKey','jobTitle'])
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.company is string
        && request.resource.data.company.size() <= 120
        && request.resource.data.get('jobKey', '') is string
        && request.resource.data.get('jobKey', '').size() <= 200
        && request.resource.data.get('jobTitle', '') is string
        && request.resource.data.get('jobTitle', '').size() <= 120;
      // v143: report ids are now DETERMINISTIC (posting__uid) so one person can
      // only ever hold ONE report per posting. Re-reporting must therefore be an
      // idempotent overwrite of YOUR OWN row — same shape-lock, and the existing
      // row's reporterUid must already be you, so nobody can overwrite anyone
      // else's report. Deletes stay closed: community history is append-only.
      allow update: if request.auth != null
        && resource.data.reporterUid == request.auth.uid
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.keys().hasOnly(['company','companyKey','stage','ts','reporterUid','jobKey','jobTitle'])
        && request.resource.data.company is string
        && request.resource.data.company.size() <= 120
        && request.resource.data.get('jobKey', '') is string
        && request.resource.data.get('jobKey', '').size() <= 200
        && request.resource.data.get('jobTitle', '') is string
        && request.resource.data.get('jobTitle', '').size() <= 120;
      allow delete: if false;
    }

    // v128: post-apply email dedupe/rate ledger — written ONLY by the Vercel
    // endpoint via the admin SDK (bypasses rules). No client touches it.
    match /apply_emails/{id} {
      allow read, write: if isAdmin();
    }

    // v125 (ops): client error telemetry — shape-locked, no PII, create-only.
    // The signed-in gate keeps a spam flood from costing writes; reads are
    // admin-only (nobody can mine other users' error traces).
    match /client_errors/{id} {
      allow read: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['msg','src','line','ua','v','ts'])
        && request.resource.data.msg is string && request.resource.data.msg.size() <= 200
        && request.resource.data.src is string && request.resource.data.src.size() <= 120
        && request.resource.data.line is number
        && request.resource.data.ua is string && request.resource.data.ua.size() <= 80
        && request.resource.data.v is string && request.resource.data.v.size() <= 12
        && request.resource.data.ts is number;
      allow update, delete: if false;
    }

    // hired — any signed-in create/read (aggregate "what got people hired" pool).
    // v101b Sprint 3: the app payload is ANONYMOUS by design (roleKey, titleRaw,
    // skills[], region-state, ts). Since any signed-in user can READ this pool,
    // enforce the no-PII invariant at the rules layer: reject a create that
    // carries any identifying key. Reads stay open (the feature needs the pool).
    match /hired/{doc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && !request.resource.data.keys().hasAny(
             ['email','name','firstName','lastName','contact','phone','uid','userId','address']);
      allow update, delete: if false;
    }

    // ======================= NEW: RECRUITER TIER ============================
    // v112 helpers — a company_invite is the ONLY way to be granted a companyId,
    // a role, or inherited verification. The invite is created by an already-verified
    // company admin (rules below), so its fields are trustworthy.
    function inviteData(id) {
      return get(/databases/$(database)/documents/company_invites/$(id)).data;
    }
    function grantMatchesInvite(d) {
      return d.get('inviteId', '') != ''
        && exists(/databases/$(database)/documents/company_invites/$(d.inviteId))
        && inviteData(d.inviteId).email == request.auth.token.email      // only the invited ADDRESS
        && inviteData(d.inviteId).companyId == d.get('companyId', '')
        && inviteData(d.inviteId).role == d.get('role', '')
        && inviteData(d.inviteId).get('inheritValidated', false) == d.get('isValidated', false)
        && inviteData(d.inviteId).get('plan', 'free') == d.get('plan', 'free');
    }
    // is the caller an owner/admin of this company? (company-scoped only — NEVER site admin)
    function isCompanyAdmin(companyId) {
      return isRecruiterVerified()
        // legacy pre-v112 owner docs have no companyId — fall back to their own domain
        && ( recruiterCompanyId() == companyId
             || ( recruiterCompanyId() == '' && recruiterDomain() == companyId && companyId != '' ) )
        && recruiterRole() in ['owner', 'admin', 'recruiter'];   // 'recruiter' = LEGACY owner docs (pre-v112)
    }
    match /recruiters/{rId} {
      // own doc, site admin, or a teammate at the SAME company (so the Team list works).
      // Legacy pre-v112 owner docs have no companyId — fall back to their own domain,
      // exactly like isCompanyAdmin, so an existing owner can still see their team.
      allow read:   if (request.auth != null && request.auth.uid == rId) || isAdmin()
        || (isRecruiter()
            && resource.data.get('companyId', '') != ''
            && ( resource.data.get('companyId', '') == recruiterCompanyId()
                 || ( recruiterCompanyId() == '' && resource.data.get('companyId', '') == recruiterDomain() ) ));
      // v112 SECURITY FIX: create had NO field restrictions, so a crafted create could
      // self-set isValidated:true and gain verified-recruiter powers (the update rule
      // blocked self-flipping, but create never did). Plain signup is now forced to
      // unverified/free/no-company/no-admin; the ONLY escalation path is a matching
      // company invite addressed to the caller's own email.
      allow create: if request.auth != null && request.auth.uid == rId
        && (
             // (a) plain employer signup: unverified, free, owner-only, and BOTH domain
             //     and companyId bound to the caller's OWN verified email domain — so
             //     nobody can create a recruiter doc claiming another company's domain
             //     (which would otherwise grant writes on companies/{thatDomain}).
             ( request.resource.data.get('isValidated', false) == false
               && request.resource.data.get('plan', 'free') == 'free'
               && !( request.resource.data.get('role', 'owner') in ['admin', 'standard'] )
               && request.resource.data.get('domain', '') == request.auth.token.email.split('@')[1]
               && ( request.resource.data.get('companyId', '') == ''
                    || request.resource.data.get('companyId', '') == request.auth.token.email.split('@')[1] ) )
             // (b) invited teammate: every granted field must match an invite addressed
             //     to this caller's own email (the invite was made by a verified admin)
             || grantMatchesInvite(request.resource.data)
           );
      // a recruiter may edit their own profile but NOT self-flip verification/plan,
      // and (v112) NOT self-escalate their company role — otherwise a 'standard'
      // teammate could simply write role:'admin' onto their own doc.
      allow update: if isAdmin()
        || (request.auth != null && request.auth.uid == rId
            && !( 'isValidated' in request.resource.data
                  && request.resource.data.isValidated != resource.data.get('isValidated', false) )
            && !( 'plan' in request.resource.data
                  && request.resource.data.plan != resource.data.get('plan', 'free') )
            && !( 'role' in request.resource.data
                  && request.resource.data.role != resource.data.get('role', 'owner') )
            // companyId may be back-filled ONCE from empty to your OWN email domain
            // (legacy pre-v112 owner docs), but never re-pointed at another company.
            && ( !('companyId' in request.resource.data)
                 || request.resource.data.companyId == resource.data.get('companyId', '')
                 || ( resource.data.get('companyId', '') == ''
                      && request.resource.data.companyId == recruiterDomain()
                      && recruiterDomain() != '' ) ));
      // v123: delete-my-account — a recruiter may remove their OWN doc (profiles
      // already allow this via wipeProfile). Teammates/strangers still cannot.
      allow delete: if isAdmin()
        || (request.auth != null && request.auth.uid == rId);
    }

    // canonical company records — public READ; reputation/verified fields backend-only.
    // v101b Sprint 3: the deployed rule was admin-only WRITE, so recruiter signup's
    // saveCompany(domain,…) was silently denied (fb.saveCompany swallows the error).
    // Now a recruiter may create/update ONLY the company doc for THEIR OWN email
    // domain (companyId == their recruiter doc's domain), and may NEVER self-set
    // verifiedEmployer:true — that reputation flag stays admin/backend only.
    match /companies/{companyId} {
      allow read: if true;
      // v112: company INFO is admin-scoped. A 'standard' teammate can list roles and
      // hire, but may not rewrite the company record — only the owner/admins can.
      // (Company admin is company-scoped and is never site admin.)
      allow create, update: if isAdmin()
        || (isRecruiter()
            && companyId == recruiterDomain()
            && recruiterDomain() != ''
            && recruiterRole() in ['owner', 'admin', 'recruiter']   // 'recruiter' = LEGACY owner docs (pre-v112)
            && request.resource.data.get('verifiedEmployer', false) == false);
      allow delete: if isAdmin();
    }

    // recruiter-visible candidate projection — backend-written; contact only when
    // the backend confirmed consent. Clients never write.
    // v101b Sprint 3: VERIFIED recruiters only (was bare isRecruiter) — a
    // self-signed-up, unreviewed recruiter must not see candidate data.
    match /candidate_cards/{candUid} {
      allow read:  if isAdmin() || isRecruiterVerified();
      allow write: if false;
    }

    // per-candidate match-token cache — backend-written; self/admin/verified-recruiter read
    match /match_tokens/{candUid} {
      allow read:  if (request.auth != null && request.auth.uid == candUid) || isAdmin() || isRecruiterVerified();
      allow write: if false;
    }

    // candidate notification tray — self read/update; inbound backend-written
    match /notifications/{userId}/items/{itemId} {
      allow read:   if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow update: if request.auth != null && request.auth.uid == userId;
      allow create, delete: if false;
    }

    // review appeals — recruiter files own; admin-only read/decide
    match /appeals/{appealId} {
      allow create: if isRecruiter() && request.resource.data.ownerUid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // R5 — recruiter → candidate OUTREACH (reach-outs + rejection notices).
    // Consent enforced AT WRITE: a verified recruiter may only reach a candidate
    // who is discoverable (a match_token exists → opted in) OR who applied to the
    // job. The candidate reads their own + sets the status (interested/declined);
    // the recruiter reads what they sent. Nobody deletes (anti-ghosting audit).
    function candidateReachable(cand, jobId) {
      return exists(/databases/$(database)/documents/match_tokens/$(cand))
        || exists(/databases/$(database)/documents/jobs/$(jobId)/applications/$(cand));
    }
    match /reachouts/{id} {
      allow read: if isAdmin()
        || (request.auth != null
            && (resource.data.toCandidateUid == request.auth.uid
                || resource.data.fromRecruiterUid == request.auth.uid));
      allow create: if isRecruiterVerified()
        && request.resource.data.fromRecruiterUid == request.auth.uid
        && request.resource.data.keys().hasAll(['fromRecruiterUid','toCandidateUid','jobId','kind','status','ts'])
        && request.resource.data.status == 'sent'
        && (request.resource.data.kind == 'reachout' || request.resource.data.kind == 'rejection')
        && request.resource.data.get('message', '').size() <= 800
        // R7: optional proposed interview slots ride along on a reach-out (bounded list of short strings)
        && request.resource.data.get('proposedTimes', []).size() <= 5
        // v148: optional interview modality offer + the recruiter's (non-secret) contact.
        // The CANDIDATE's contact is NEVER on a create — it is written only when the
        // candidate accepts (see the candidate update rule), which is the consent gate.
        && request.resource.data.get('modalities', []).size() <= 3
        && request.resource.data.get('interviewDetails', {}).get('address', '').size() <= 200
        && request.resource.data.get('interviewDetails', {}).get('link', '').size() <= 300
        && request.resource.data.get('interviewDetails', {}).get('phone', '').size() <= 40
        && request.resource.data.get('recruiterContact', {}).get('email', '').size() <= 120
        && request.resource.data.get('recruiterContact', {}).get('name', '').size() <= 80
        && candidateReachable(request.resource.data.toCandidateUid, request.resource.data.jobId);
      // The recipient CANDIDATE may respond: accept/decline (R6), pick a proposed
      // interview slot (R7 acceptedTime), appeal a rejection (R5), or request a
      // reschedule (v127). Immutable identity fields; bounded strings.
      allow update: if request.auth != null
        && resource.data.toCandidateUid == request.auth.uid
        && request.resource.data.toCandidateUid == resource.data.toCandidateUid
        && request.resource.data.fromRecruiterUid == resource.data.fromRecruiterUid
        && request.resource.data.jobId == resource.data.jobId
        && request.resource.data.kind == resource.data.kind
        // v148: a candidate may also CANCEL a confirmed interview from their side.
        && request.resource.data.status in ['interested', 'declined', 'appealed', 'reschedule-requested', 'cancelled']
        && request.resource.data.get('acceptedTime', '').size() <= 200
        && request.resource.data.get('appealMessage', '').size() <= 400
        && request.resource.data.get('rescheduleNote', '').size() <= 300
        // v148: accepting shares the candidate's OWN contact + chosen modality; a
        // candidate-side cancel carries an optional reason. All bounded.
        && request.resource.data.get('chosenModality', '').size() <= 20
        && request.resource.data.get('cancelNote', '').size() <= 300
        && request.resource.data.get('candidateContact', {}).get('email', '').size() <= 120
        && request.resource.data.get('candidateContact', {}).get('name', '').size() <= 80
        && request.resource.data.get('candidateContact', {}).get('phone', '').size() <= 40
        // an appeal is only valid against a rejection notice (anti-ghosting accountability)
        && (request.resource.data.status != 'appealed' || resource.data.kind == 'rejection');
      // v127: the SENDING recruiter may reschedule (re-propose times -> 'sent') or
      // cancel with a respectful note. Identity fields stay immutable; a recruiter
      // can never flip an appeal or forge a candidate response.
      allow update: if request.auth != null
        && resource.data.fromRecruiterUid == request.auth.uid
        && request.resource.data.fromRecruiterUid == resource.data.fromRecruiterUid
        && request.resource.data.toCandidateUid == resource.data.toCandidateUid
        && request.resource.data.jobId == resource.data.jobId
        && request.resource.data.kind == resource.data.kind
        && request.resource.data.status in ['sent', 'cancelled']
        && request.resource.data.get('proposedTimes', []).size() <= 5
        // v148: a reschedule may re-offer modalities; a cancel carries an optional note.
        && request.resource.data.get('modalities', []).size() <= 3
        && request.resource.data.get('cancelNote', '').size() <= 300;
      allow delete: if false;
    }

    // ---- Company team invites (v112) -------------------------------------------
    // A company admin/owner invites a colleague by email. The invite is the ONLY
    // grant of a companyId / role / inherited verification (see grantMatchesInvite).
    // The doc id IS the secret (it rides in the emailed link), and acceptance is
    // additionally gated on the caller's own verified email matching the invite —
    // so a leaked link still can't be redeemed by anyone else.
    match /company_invites/{inviteId} {
      // the inviting company can list its own invites; the invited address can read theirs
      allow read: if isAdmin()
        || (request.auth != null
            && (resource.data.email == request.auth.token.email
                || isCompanyAdmin(resource.data.companyId)));
      allow create: if isCompanyAdmin(request.resource.data.companyId)
        && request.resource.data.keys().hasAll(['companyId','email','role','invitedBy','status','ts'])
        && request.resource.data.invitedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.role in ['admin', 'standard']      // never 'owner', never site-admin
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 160;
      // only the invited ADDRESS may accept, and only into 'accepted'
      allow update: if request.auth != null
        && resource.data.email == request.auth.token.email
        && request.resource.data.email == resource.data.email
        && request.resource.data.companyId == resource.data.companyId
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == 'accepted';
      // an admin of the company may revoke a pending seat
      allow delete: if isAdmin() || isCompanyAdmin(resource.data.companyId);
    }

    // ---- Referral engine (v107): one doc per invitee, keyed by their uid --------
    // The invitee owns their record. referrerCode is the referrer's uid. Reads are
    // allowed to the invitee (own doc) and the referrer (query where referrerCode ==
    // their uid). No self-referral; onboarded only flips true; no deletes.
    match /referrals/{inviteeUid} {
      allow read: if request.auth != null
        && (resource.data.inviteeUid == request.auth.uid
            || resource.data.referrerCode == request.auth.uid);
      allow create: if request.auth != null
        && inviteeUid == request.auth.uid
        && request.resource.data.inviteeUid == request.auth.uid
        && request.resource.data.referrerCode is string
        && request.resource.data.referrerCode != request.auth.uid           // no self-referral
        && request.resource.data.get('onboarded', false) == false
        && request.resource.data.keys().hasAll(['referrerCode','inviteeUid','onboarded','ts']);
      allow update: if request.auth != null
        && inviteeUid == request.auth.uid
        && request.resource.data.inviteeUid == resource.data.inviteeUid
        && request.resource.data.referrerCode == resource.data.referrerCode  // code immutable
        && request.resource.data.onboarded == true;                          // only ever flips to onboarded
      allow delete: if false;
    }

    // default deny (implicit — no catch-all needed; unmatched paths are denied)
  }
}
