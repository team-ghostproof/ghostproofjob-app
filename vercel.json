{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }]
    }
  ],
  "functions": {
    "api/jobs/*.js": {
      "memory": 2048,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/jobs/index",
      "schedule": "0 5 * * *"
    }
  ]
}
